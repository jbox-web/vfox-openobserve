#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force openobserve .
mise cache clear
mise install openobserve@0.70.0

# Capture and display the output while also verifying it
output=$(mise exec "openobserve@0.70.0" -- "openobserve" --version)
echo "openobserve output: ${output}"

if echo "${output}" | grep -q '0.70.0'; then
  echo "✓ Tests passed"
else
  echo "✗ Test failed: expected version openobserve@0.70.0"
  exit 1
fi
